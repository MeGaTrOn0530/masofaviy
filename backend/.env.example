NODE_ENV=development
PORT=4001
# Agar xohlasangiz DATABASE_URL ni to'g'ridan-to'g'ri yozishingiz mumkin.
DATABASE_URL=""
MYSQL_HOST=127.0.0.1
MYSQL_PORT=3306
MYSQL_DATABASE=meeting_service
MYSQL_USER=root
MYSQL_PASSWORD=
MYSQL_SSL=false
JWT_SECRET="change-me-access-secret"
JOIN_TOKEN_SECRET="change-me-join-secret"
MAIN_BACKEND_MODE=mock
MAIN_BACKEND_URL="http://localhost:3000"
MAIN_BACKEND_ATTENDANCE_PATH="/api/attendance/meeting"
MAIN_BACKEND_EVENT_PATH="/api/integrations/meeting-events"
MAIN_BACKEND_SERVICE_KEY="meeting-service-key"
DEV_AUTH_ENABLED=true
DEV_FILE_STORE_FALLBACK=false
FILE_STORE_PATH=".data/dev-store.json"
CORS_ORIGINS="http://localhost:5173,http://localhost:4173"
SOCKET_PATH="/socket.io"
RATE_LIMIT_WINDOW_MS=60000
RATE_LIMIT_MAX=120
ATTENDANCE_SYNC_INTERVAL_MS=30000
ATTENDANCE_SYNC_MAX_RETRIES=10
MEDIASOUP_LISTEN_IP=127.0.0.1
MEDIASOUP_MIN_PORT=40000
MEDIASOUP_MAX_PORT=49999
MEDIASOUP_ANNOUNCED_IP=""
